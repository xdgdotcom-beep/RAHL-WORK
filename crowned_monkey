.tech-icon{width:50px;height:50px;margin:0 auto 12px;position:relative;z-index:1}
.tech-title{font-family:'Cinzel',serif;font-size:clamp(13px,1.7vw,19px);letter-spacing:.04em;color:var(--ice);margin-bottom:5px;position:relative;z-index:1}
.tech-desc{font-family:'Playfair Display',serif;font-size:clamp(11px,1.2vw,13px);line-height:1.65;color:rgba(232,240,248,.4);position:relative;z-index:1}
