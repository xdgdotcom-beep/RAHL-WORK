<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Crowned Monkey — Sci-Fi Mixology Lab · Business Case 2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Rajdhani:wght@300;400;500;600&family=Cinzel:wght@400;600;700&display=swap" rel="stylesheet"/>
<style>
:root{
  --navy:#07091A;--navy2:#0C0F28;--navy3:#131730;
  --gold:#C9A84C;--gold2:#E8C96A;--gold3:#F5E4A8;
  --ice:#E8F0F8;--ice2:rgba(232,240,248,.65);
  --teal:#00C9B8;--teal2:rgba(0,201,184,.2);
  --rose:#C84C6A;--smoke:rgba(232,240,248,.38);
  --px:clamp(18px,5vw,72px);--gap:clamp(10px,1.5vw,18px);--r:2px;
  --gold-line:linear-gradient(90deg,transparent,var(--gold),var(--gold2),transparent);
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--navy);color:var(--ice);font-family:'Rajdhani',sans-serif;overflow-x:hidden;-webkit-font-smoothing:antialiased;cursor:none}
a{text-decoration:none;color:inherit}
img{display:block;max-width:100%}
body::before{content:'';position:fixed;inset:0;z-index:1;pointer-events:none;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");opacity:.028;mix-blend-mode:overlay;}
body::after{content:'';position:fixed;inset:0;z-index:0;pointer-events:none;background-image:linear-gradient(rgba(201,168,76,.028) 1px,transparent 1px),linear-gradient(90deg,rgba(201,168,76,.028) 1px,transparent 1px);background-size:52px 52px;mask-image:radial-gradient(ellipse 80% 80% at 50% 50%,black 30%,transparent 100%);}
.deco-corner{position:absolute;width:28px;height:28px;pointer-events:none;z-index:10}
.deco-corner.tl{top:14px;left:14px;border-top:1.5px solid var(--gold);border-left:1.5px solid var(--gold)}
.deco-corner.tr{top:14px;right:14px;border-top:1.5px solid var(--gold);border-right:1.5px solid var(--gold)}
.deco-corner.bl{bottom:14px;left:14px;border-bottom:1.5px solid var(--gold);border-left:1.5px solid var(--gold)}
.deco-corner.br{bottom:14px;right:14px;border-bottom:1.5px solid var(--gold);border-right:1.5px solid var(--gold)}
#CUR{position:fixed;top:0;left:0;z-index:99999;pointer-events:none;will-change:transform}
#CDT{width:8px;height:8px;border-radius:50%;background:var(--gold);position:absolute;transform:translate(-50%,-50%);mix-blend-mode:screen}
#CRG{width:28px;height:28px;border:1px solid rgba(201,168,76,.5);border-radius:50%;position:absolute;transform:translate(-50%,-50%);transition:width .2s,height .2s}
body.hov #CRG{width:46px;height:46px;border-color:var(--gold)}

/* ══ COCKTAIL SCROLL BAR ══ */
#PBAR{
  position:fixed;top:0;left:0;right:0;height:3px;z-index:600;
  background:rgba(7,9,26,.9);
  pointer-events:none;will-change:transform;
  overflow:visible;
  contain:strict;
}
#PBAR-FILL{
  height:100%;
  background:linear-gradient(90deg,var(--teal),var(--gold),var(--gold2));
  transform:scaleX(0);
  transform-origin:left;
  will-change:transform;
  position:relative;
  contain:layout style;
}
/* Animated cocktail glass icon that rides the bar */
#PBAR-GLASS{
  position:absolute;
  right:-14px;
  top:-10px;
  width:28px;
  height:28px;
  pointer-events:none;
}
#PBAR-GLASS svg{width:100%;height:100%}
/* Shimmer — GPU transform only, no background-position repaint */
#PBAR-FILL::after{
  content:'';
  position:absolute;
  top:0;left:0;bottom:0;
  width:60px;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,.38),transparent);
  animation:barShimmer 1.9s ease-in-out infinite;
  will-change:transform;
}
@keyframes barShimmer{
  from{transform:translateX(-60px)}
  to{transform:translateX(100vw)}
}

#BTT{position:fixed;bottom:68px;right:20px;z-index:500;width:36px;height:36px;background:rgba(201,168,76,.08);border:1px solid rgba(201,168,76,.25);border-radius:2px;display:flex;align-items:center;justify-content:center;cursor:pointer;opacity:0;transform:translateY(14px);transition:opacity .3s,transform .3s,background .2s;font-size:14px;color:var(--gold);}
#BTT.vis{opacity:1;transform:none}
#BTT:hover{background:rgba(201,168,76,.18)}

/* 3D LAB BUTTON */
#LAB3D-BTN{
  position:fixed;bottom:110px;right:20px;z-index:500;
  width:auto;padding:8px 14px;
  background:rgba(0,201,184,.08);border:1px solid rgba(0,201,184,.35);
  border-radius:2px;display:flex;align-items:center;gap:7px;
  cursor:pointer;
  transition:background .2s,border-color .2s,transform .2s;
  font-family:'Rajdhani',sans-serif;font-size:7px;letter-spacing:.22em;
  text-transform:uppercase;color:var(--teal);font-weight:600;
}
#LAB3D-BTN:hover{background:rgba(0,201,184,.15);border-color:var(--teal);transform:translateY(-2px)}
#LAB3D-BTN .btn-dot{width:5px;height:5px;border-radius:50%;background:var(--teal);animation:tdPulse 1.5s ease-in-out infinite}
@keyframes tdPulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.6);opacity:.5}}

/* 3D LAB MODAL */
#LAB3D-MODAL{
  position:fixed;inset:0;z-index:10000;
  background:rgba(7,9,26,.95);backdrop-filter:blur(18px);
  display:flex;align-items:center;justify-content:center;
  opacity:0;pointer-events:none;
  transition:opacity .4s cubic-bezier(.16,1,.3,1);
}
#LAB3D-MODAL.open{opacity:1;pointer-events:all}
.modal-inner{
  position:relative;width:min(92vw,960px);height:min(88vh,640px);
  background:var(--navy2);border:1px solid rgba(201,168,76,.2);
  border-radius:4px;overflow:hidden;
  transform:scale(.92) translateY(20px);
  transition:transform .45s cubic-bezier(.16,1,.3,1);
}
#LAB3D-MODAL.open .modal-inner{transform:scale(1) translateY(0)}
.modal-header{
  position:absolute;top:0;left:0;right:0;z-index:10;
  padding:14px 20px;display:flex;align-items:center;justify-content:space-between;
  background:linear-gradient(180deg,rgba(7,9,26,.9),transparent);
  pointer-events:none;
}
.modal-title{font-family:'Cinzel',serif;font-size:13px;letter-spacing:.12em;color:var(--gold)}
.modal-sub{font-family:'Rajdhani',sans-serif;font-size:7px;letter-spacing:.28em;text-transform:uppercase;color:rgba(0,201,184,.6);margin-top:1px;font-weight:500}
.modal-close{
  position:absolute;top:12px;right:14px;z-index:20;
  width:32px;height:32px;border:1px solid rgba(201,168,76,.25);
  background:rgba(7,9,26,.8);border-radius:2px;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;color:var(--gold);font-size:14px;
  transition:background .2s;pointer-events:all;
}
.modal-close:hover{background:rgba(201,168,76,.12)}
.modal-controls{
  position:absolute;bottom:14px;left:50%;transform:translateX(-50%);z-index:10;
  display:flex;gap:8px;pointer-events:all;
}
.ctrl-btn{
  font-family:'Rajdhani',sans-serif;font-size:7px;letter-spacing:.18em;
  text-transform:uppercase;padding:5px 12px;border:1px solid rgba(201,168,76,.2);
  border-radius:2px;color:rgba(201,168,76,.5);cursor:pointer;background:rgba(7,9,26,.7);
  transition:all .18s;font-weight:500;backdrop-filter:blur(8px);
}
.ctrl-btn:hover,.ctrl-btn.active{background:rgba(201,168,76,.1);border-color:var(--gold);color:var(--gold)}
#LAB3D-CANVAS{width:100%;height:100%;display:block}
.modal-hint{
  position:absolute;bottom:52px;left:50%;transform:translateX(-50%);
  font-family:'Rajdhani',sans-serif;font-size:7px;letter-spacing:.2em;
  text-transform:uppercase;color:rgba(232,240,248,.2);white-space:nowrap;
  pointer-events:none;
}

#KTOAST{position:fixed;bottom:20px;left:50%;transform:translateX(-50%) translateY(80px);z-index:600;background:rgba(7,9,26,.92);border:1px solid rgba(201,168,76,.2);backdrop-filter:blur(12px);border-radius:4px;padding:10px 18px;display:flex;align-items:center;gap:10px;transition:transform .4s cubic-bezier(.16,1,.3,1),opacity .3s;opacity:0;}
#KTOAST.show{transform:translateX(-50%) translateY(0);opacity:1}
#KTOAST span{font-family:'Rajdhani',sans-serif;font-size:9px;letter-spacing:.2em;color:rgba(232,240,248,.5);font-weight:500}
.ktag{font-family:'Rajdhani',sans-serif;font-size:8px;letter-spacing:.1em;padding:2px 7px;border:1px solid rgba(201,168,76,.3);color:var(--gold);border-radius:2px}
#PL{position:fixed;inset:0;z-index:9998;background:var(--navy);display:flex;flex-direction:column;align-items:center;justify-content:center;transition:opacity .8s,visibility .8s}
#PL.gone{opacity:0;visibility:hidden;pointer-events:none}
.pl-ring{width:80px;height:80px;border-radius:50%;border:1px solid rgba(201,168,76,.2);border-top-color:var(--gold);animation:plSpin 1s linear infinite;position:relative;margin-bottom:28px}
.pl-ring::after{content:'👑';position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:22px;animation:plSpin 3s linear infinite reverse}
@keyframes plSpin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
.pl-logo{font-family:'Cinzel',serif;font-size:clamp(24px,5.5vw,56px);letter-spacing:.18em;color:var(--gold);opacity:0;animation:plIn .7s ease .2s both;text-align:center}
@keyframes plIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}
.pl-sub{font-family:'Rajdhani',sans-serif;font-size:9px;letter-spacing:.5em;text-transform:uppercase;color:var(--smoke);margin-top:6px;opacity:0;animation:plIn .6s ease .4s both}
.pl-bar{width:160px;height:1px;background:rgba(201,168,76,.15);margin-top:22px;position:relative;overflow:hidden}
.pl-fill{position:absolute;inset:0;width:0%;background:linear-gradient(90deg,var(--teal),var(--gold));transition:width .16s}
.pl-pct{font-family:'Rajdhani',sans-serif;font-size:10px;letter-spacing:.3em;color:var(--gold);margin-top:5px;opacity:0;animation:plIn .5s ease .55s both}
#SNAV{position:fixed;right:20px;top:50%;transform:translateY(-50%);z-index:500;display:flex;flex-direction:column;gap:10px}
.snd{width:4px;height:4px;border-radius:1px;background:rgba(201,168,76,.2);border:1px solid rgba(201,168,76,.15);transition:background .25s,transform .25s,width .25s;position:relative;cursor:pointer;transform:rotate(45deg)}
.snd.on{background:var(--gold);transform:rotate(45deg) scale(1.6)}
.snd::after{content:attr(data-l);position:absolute;right:12px;top:50%;transform:translateY(-50%) rotate(-45deg);font-family:'Rajdhani',sans-serif;font-size:7px;letter-spacing:.2em;text-transform:uppercase;color:var(--smoke);white-space:nowrap;opacity:0;transition:opacity .18s;pointer-events:none}
.snd:hover::after{opacity:1}
@media(max-width:768px){#SNAV{display:none}}
#PRING{position:fixed;bottom:20px;right:20px;z-index:500;width:36px;height:36px;pointer-events:none}
#PRING svg{transform:rotate(-90deg)}
.rbg{fill:none;stroke:rgba(201,168,76,.08);stroke-width:1.5}
.rfg{fill:none;stroke:var(--gold);stroke-width:1.5;stroke-linecap:round;stroke-dasharray:100;stroke-dashoffset:100;will-change:stroke-dashoffset}
#RNUM{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:'Rajdhani',sans-serif;font-size:7px;color:rgba(201,168,76,.6);letter-spacing:.1em}
.hex-field{position:absolute;inset:0;overflow:hidden;pointer-events:none;z-index:0}
.hex{position:absolute;width:0;height:0;border-left:16px solid transparent;border-right:16px solid transparent;border-bottom:28px solid rgba(201,168,76,.04);animation:hexFloat ease-in-out infinite}
.hex::after{content:'';position:absolute;top:28px;left:-16px;width:0;height:0;border-left:16px solid transparent;border-right:16px solid transparent;border-top:28px solid rgba(201,168,76,.04)}
@keyframes hexFloat{0%,100%{transform:translateY(0) rotate(0deg);opacity:.4}33%{transform:translateY(-22px) rotate(5deg);opacity:.7}66%{transform:translateY(-8px) rotate(-3deg);opacity:.5}}
.scan-ring{position:absolute;border-radius:50%;border:1px solid var(--teal);opacity:0;animation:scanPulse ease-out infinite;pointer-events:none}
@keyframes scanPulse{0%{transform:scale(.2);opacity:.6}100%{transform:scale(2.5);opacity:0}}
.drip{position:absolute;top:0;width:1px;background:linear-gradient(180deg,transparent,var(--gold),var(--gold2),transparent);animation:dripFall linear infinite;pointer-events:none}
@keyframes dripFall{0%{transform:translateY(-100%);opacity:0}10%{opacity:1}90%{opacity:.4}100%{transform:translateY(100vh);opacity:0}}
.wand{height:1px;max-width:480px;background:var(--gold-line);position:relative;overflow:hidden;margin:10px 0 22px;clip-path:inset(0 100% 0 0);animation:wandReveal .9s cubic-bezier(.16,1,.3,1) .95s both}
@keyframes wandReveal{to{clip-path:inset(0 0% 0 0)}}
.wand-beam{position:absolute;top:-4px;left:-14%;width:12%;height:9px;background:radial-gradient(ellipse,rgba(232,201,106,.9),transparent 70%);border-radius:50%;animation:beamGo 2s ease-in-out infinite}
@keyframes beamGo{0%{transform:translateX(0);opacity:0}12%{opacity:1}86%{opacity:1}100%{transform:translateX(560px);opacity:0}}
.hat{font-size:clamp(24px,3.8vw,48px);display:inline-block;animation:hatBob 3s ease-in-out infinite;filter:drop-shadow(0 0 12px rgba(201,168,76,.7))}
@keyframes hatBob{0%,100%{transform:translateY(0) rotate(-3deg)}50%{transform:translateY(-8px) rotate(3deg)}}
@keyframes nameReveal{from{opacity:0;transform:translateY(30px) skewX(-4deg)}to{opacity:1;transform:none}}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
.hstar{position:absolute;opacity:0;font-size:10px;pointer-events:none;animation:starPop ease-in-out infinite}
@keyframes starPop{0%{opacity:0;transform:translate(0,0) scale(.1)}30%{opacity:1}100%{opacity:0;transform:translate(var(--sx,0),var(--sy,0)) scale(.05)}}
.hstar:nth-child(2){--sx:-8px;--sy:-50px;top:-15px;left:14%;animation-duration:2.4s}
.hstar:nth-child(3){--sx:7px;--sy:-56px;top:-21px;left:45%;animation-duration:2.8s;animation-delay:.4s}
.hstar:nth-child(4){--sx:-5px;--sy:-42px;top:-12px;left:67%;animation-duration:2.5s;animation-delay:.8s}
.hstar:nth-child(5){--sx:10px;--sy:-60px;top:-27px;left:32%;animation-duration:2.9s;animation-delay:1.1s}
.scroll-rod{width:1px;height:38px;position:relative;overflow:hidden;background:rgba(201,168,76,.1)}
.scroll-rod::after{content:'';position:absolute;top:-100%;left:0;width:100%;height:100%;background:linear-gradient(180deg,transparent,var(--gold),transparent);animation:rodSlide 1.8s ease-in-out infinite}
@keyframes rodSlide{0%{transform:translateY(0)}100%{transform:translateY(300%)}}
.cost-fill{height:100%;background:linear-gradient(90deg,var(--teal),var(--gold));transform:scaleX(0);transform-origin:left;transition:transform 1.2s cubic-bezier(.16,1,.3,1);will-change:transform}
.cost-fill.go{transform:scaleX(1)}
.spark{position:absolute;width:2px;height:2px;border-radius:50%;background:var(--gold2);pointer-events:none;animation:sparkUp ease-out forwards}
@keyframes sparkUp{0%{transform:translateY(0) scale(1);opacity:1}100%{transform:translateY(-60px) scale(0);opacity:0}}
.mol-spin{animation:molSpin 12s linear infinite;transform-origin:center}
@keyframes molSpin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
.mol-spin-rev{animation:molSpin 9s linear infinite reverse;transform-origin:center}
.n2d{animation:n2Fall ease-in infinite}
.n2d:nth-child(2){animation-delay:.55s}
.n2d:nth-child(3){animation-delay:1.1s}
@keyframes n2Fall{0%{opacity:0;transform:translateY(-8px)}28%{opacity:.9}100%{opacity:0;transform:translateY(26px)}}
.smp{transform-origin:50% 100%;animation:smokeW 2.9s ease-in-out infinite}
.smp:nth-child(2){animation-delay:.45s}
.smp:nth-child(3){animation-delay:.9s}
@keyframes smokeW{0%,100%{transform:scaleX(1);opacity:.3}50%{transform:scaleX(1.35);opacity:.72}}
.mq-wrap{overflow:hidden;padding:12px 0;border-top:1px solid rgba(201,168,76,.1);border-bottom:1px solid rgba(201,168,76,.1);z-index:2;position:relative}
.mq-track{display:flex;width:max-content}
.mq-fwd{animation:mqF 28s linear infinite}
.mq-rev{animation:mqR 34s linear infinite}
@keyframes mqF{from{transform:translateX(0)}to{transform:translateX(-50%)}}
@keyframes mqR{from{transform:translateX(-50%)}to{transform:translateX(0)}}
.mq-wrap:hover .mq-track{animation-play-state:paused}
.mqi{font-family:'Rajdhani',sans-serif;font-size:clamp(9px,1.3vw,13px);letter-spacing:.32em;color:rgba(201,168,76,.14);white-space:nowrap;padding:0 22px;font-weight:500}
.mqi em{color:rgba(0,201,184,.22);font-style:normal}
.mqi.lit{color:rgba(0,201,184,.14)}
.hero{position:relative;min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;overflow:hidden}
#HBGIMG{position:absolute;inset:-6%;background:url('https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?w=1600&q=80&fit=crop') center/cover;filter:brightness(.28) saturate(.4) hue-rotate(200deg);will-change:transform}
.hero-ov{position:absolute;inset:0;z-index:1;background:linear-gradient(155deg,rgba(7,9,26,.98) 20%,rgba(7,9,26,.1) 55%,rgba(7,9,26,.92) 100%)}
.hero-content{position:relative;z-index:3;padding:clamp(72px,9vw,116px) var(--px) clamp(50px,6vw,80px);max-width:1400px;width:100%}
.h-kick{font-family:'Rajdhani',sans-serif;font-size:8px;letter-spacing:.5em;text-transform:uppercase;color:var(--teal);display:flex;align-items:center;gap:14px;margin-bottom:18px;clip-path:inset(0 100% 0 0);animation:wandReveal .75s cubic-bezier(.16,1,.3,1) .28s both}
.h-kick::before{content:'';width:28px;height:1px;background:linear-gradient(90deg,transparent,var(--teal))}
.n-wrap{display:flex;align-items:baseline;gap:clamp(4px,1vw,12px);flex-wrap:wrap;margin-bottom:8px}
.h-el{font-family:'Cinzel',serif;font-size:clamp(48px,10vw,148px);color:var(--ice);line-height:.84;letter-spacing:.04em;opacity:0;animation:nameReveal .95s cubic-bezier(.16,1,.3,1) .42s both}
.h-mago{font-family:'Playfair Display',serif;font-style:italic;font-size:clamp(44px,9.5vw,136px);background:linear-gradient(135deg,var(--gold) 0%,var(--gold2) 50%,var(--gold3) 100%);-webkit-background-clip:text;background-clip:text;color:transparent;line-height:.84;opacity:0;animation:nameReveal .95s cubic-bezier(.16,1,.3,1) .58s both}
.hat-wrap{position:relative;display:inline-flex;align-items:center;opacity:0;animation:fadeUp .65s ease .78s both}
.h-tag{font-family:'Playfair Display',serif;font-style:italic;font-size:clamp(13px,1.6vw,18px);color:var(--smoke);max-width:480px;line-height:1.72;margin-bottom:26px;opacity:0;animation:fadeUp .65s ease .96s both}
.h-metrics{display:flex;gap:clamp(16px,3vw,48px);flex-wrap:wrap;opacity:0;animation:fadeUp .65s ease 1.1s both}
.hmi{display:flex;flex-direction:column;gap:2px;position:relative}
.hmi::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:1px;background:linear-gradient(90deg,var(--teal),transparent);transition:width .35s}
.hmi:hover::after{width:100%}
.hmv{font-family:'Cinzel',serif;font-size:clamp(24px,3.5vw,44px);letter-spacing:.04em;color:var(--gold);line-height:1}
.hml{font-family:'Rajdhani',sans-serif;font-size:7px;letter-spacing:.3em;text-transform:uppercase;color:rgba(0,201,184,.6);font-weight:500}
.scroll-ind{position:absolute;bottom:22px;left:50%;transform:translateX(-50%);z-index:3;display:flex;flex-direction:column;align-items:center;gap:5px;opacity:0;animation:fadeUp .65s ease 1.5s both}
.scroll-ind span{font-family:'Rajdhani',sans-serif;font-size:7px;letter-spacing:.3em;text-transform:uppercase;color:rgba(201,168,76,.45)}
main{position:relative;z-index:2}
.sec{padding:0 var(--px);max-width:1400px;margin:0 auto}
.fb{padding:0 var(--px);position:relative;z-index:2}
.fbi{max-width:1400px;margin:0 auto}
.gap{height:clamp(28px,4.8vw,72px)}
.gap-sm{height:16px}
.sdiv{display:flex;align-items:center;gap:14px;padding:5px 0;position:relative}
.sdiv span{font-family:'Rajdhani',sans-serif;font-size:7.5px;letter-spacing:.4em;text-transform:uppercase;color:rgba(201,168,76,.45);white-space:nowrap;font-weight:500}
.sdiv::before,.sdiv::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,transparent,rgba(201,168,76,.15),transparent)}
