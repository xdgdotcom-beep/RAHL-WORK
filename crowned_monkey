.builder-section-label{font-family:'Rajdhani',sans-serif;font-size:7px;letter-spacing:.35em;text-transform:uppercase;color:rgba(201,168,76,.4);margin-bottom:10px;font-weight:500;display:flex;align-items:center;gap:8px}
