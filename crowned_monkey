function project3D(x,y,z,canvas,cam){
  var cx=canvas.width/2,cy=canvas.height/2;
  var scale=Math.min(canvas.width,canvas.height)*0.085*cam.zoom;
  var cosY=Math.cos(cam.rotY),sinY=Math.sin(cam.rotY);
  var rx=x*cosY+z*sinY;
  var rz=-x*sinY+z*cosY;
  var cosX=Math.cos(cam.rotX),sinX=Math.sin(cam.rotX);
  var ry2=y*cosX-rz*sinX;
  var rz2=y*sinX+rz*cosX;
  return{px:cx+rx*scale, py:cy-ry2*scale+scale*1.2, depth:rz2};
}
function shadeColor(hex,percent){
  if(hex.startsWith('rgba')||hex.startsWith('rgb'))return hex;
  var num=parseInt(hex.replace('#',''),16);
  var r=Math.min(255,Math.max(0,(num>>16)+percent));
  var g=Math.min(255,Math.max(0,((num>>8)&0xff)+percent));
  var b=Math.min(255,Math.max(0,(num&0xff)+percent));
  return'#'+((1<<24)+(r<<16)+(g<<8)+b).toString(16).slice(1);
}
function drawBox(ctx,obj,canvas,cam,highlight){
  var hw=obj.w/2,hh=obj.h/2,hd=obj.d/2;
  var corners=[[-hw,obj.y-hh,-hd],[hw,obj.y-hh,-hd],[hw,obj.y+hh,-hd],[-hw,obj.y+hh,-hd],[-hw,obj.y-hh,hd],[hw,obj.y-hh,hd],[hw,obj.y+hh,hd],[-hw,obj.y+hh,hd]];
  var pts=corners.map(function(c){return project3D(obj.x+c[0],c[1],obj.z+c[2],canvas,cam);});
  var c=ctx;
  c.beginPath();c.moveTo(pts[0].px,pts[0].py);c.lineTo(pts[1].px,pts[1].py);c.lineTo(pts[5].px,pts[5].py);c.lineTo(pts[4].px,pts[4].py);c.closePath();
  c.fillStyle=shadeColor(obj.color,-20);c.fill();c.strokeStyle=highlight?'rgba(201,168,76,.8)':obj.edgeColor;c.lineWidth=highlight?1.5:.5;c.stroke();
  c.beginPath();c.moveTo(pts[4].px,pts[4].py);c.lineTo(pts[5].px,pts[5].py);c.lineTo(pts[6].px,pts[6].py);c.lineTo(pts[7].px,pts[7].py);c.closePath();
  c.fillStyle=shadeColor(obj.color,10);c.fill();c.strokeStyle=highlight?'rgba(201,168,76,.8)':obj.edgeColor;c.lineWidth=highlight?1.5:.5;c.stroke();
  c.beginPath();c.moveTo(pts[3].px,pts[3].py);c.lineTo(pts[2].px,pts[2].py);c.lineTo(pts[6].px,pts[6].py);c.lineTo(pts[7].px,pts[7].py);c.closePath();
  c.fillStyle=shadeColor(obj.color,25);c.fill();c.strokeStyle=highlight?'rgba(201,168,76,.8)':obj.edgeColor;c.lineWidth=highlight?1.5:.5;c.stroke();
  c.beginPath();c.moveTo(pts[1].px,pts[1].py);c.lineTo(pts[2].px,pts[2].py);c.lineTo(pts[6].px,pts[6].py);c.lineTo(pts[5].px,pts[5].py);c.closePath();
  c.fillStyle=shadeColor(obj.color,5);c.fill();c.strokeStyle=highlight?'rgba(201,168,76,.8)':obj.edgeColor;c.lineWidth=highlight?1.5:.5;c.stroke();
  if(obj.label&&highlight){var p=project3D(obj.x,obj.y+hh+0.15,obj.z,canvas,cam);c.font='bold 9px Rajdhani,sans-serif';c.fillStyle=obj.labelColor||'rgba(0,201,184,.9)';c.textAlign='center';c.fillText(obj.label,p.px,p.py);}
}
function drawBottle(ctx,obj,canvas,cam,highlight){
  var p0=project3D(obj.x,obj.y+0.4,obj.z,canvas,cam);
  var p1=project3D(obj.x,obj.y,obj.z,canvas,cam);
  var scale=Math.min(canvas.width,canvas.height)*0.085*cam.zoom;
  var bw=scale*.12,bh=Math.abs(p0.py-p1.py)+scale*.15;
  var bx=p1.px-bw/2,by=p1.py-bh;
  ctx.fillStyle=obj.glassColor||'rgba(200,200,255,.4)';
  ctx.strokeStyle=highlight?'rgba(201,168,76,.9)':obj.edgeColor||'rgba(201,168,76,.3)';
  ctx.lineWidth=highlight?1.2:.4;
  ctx.beginPath();ctx.roundRect(bx,by,bw,bh,2);ctx.fill();ctx.stroke();
  var nw=bw*.45,nh=bh*.3;
  ctx.fillStyle=obj.glassColor||'rgba(200,200,255,.3)';
  ctx.beginPath();ctx.roundRect(bx+bw/2-nw/2,by-nh,nw,nh,1);ctx.fill();ctx.stroke();
  if(obj.label&&highlight){ctx.font='bold 8px Rajdhani,sans-serif';ctx.fillStyle='rgba(0,201,184,.9)';ctx.textAlign='center';ctx.fillText(obj.label,p1.px,by-nh-4);}
}
function drawGlass(ctx,obj,canvas,cam){
  var p=project3D(obj.x,obj.y+0.2,obj.z,canvas,cam);
  var scale=Math.min(canvas.width,canvas.height)*0.085*cam.zoom;
  var gw=scale*.18,gh=scale*.2;
  ctx.fillStyle=obj.color||'rgba(200,230,255,.3)';
  ctx.strokeStyle=obj.edgeColor||'rgba(201,168,76,.5)';
  ctx.lineWidth=.5;
  ctx.beginPath();ctx.moveTo(p.px-gw/2,p.py-gh);ctx.lineTo(p.px+gw/2,p.py-gh);ctx.lineTo(p.px+gw*.15,p.py);ctx.lineTo(p.px+gw*.15,p.py+gh*.3);ctx.lineTo(p.px-gw*.15,p.py+gh*.3);ctx.lineTo(p.px-gw*.15,p.py);ctx.closePath();ctx.fill();ctx.stroke();
  ctx.fillStyle=obj.color.replace('.3','0.5')||'rgba(200,230,255,.5)';
  ctx.beginPath();ctx.moveTo(p.px-gw/2+2,p.py-gh+4);ctx.lineTo(p.px+gw/2-2,p.py-gh+4);ctx.lineTo(p.px+gw*.15,p.py);ctx.lineTo(p.px-gw*.15,p.py);ctx.closePath();ctx.fill();
}
function drawLight(ctx,obj,canvas,cam){
  var p=project3D(obj.x,obj.y,obj.z,canvas,cam);
  var p2=project3D(obj.x,obj.y-0.3,obj.z,canvas,cam);
  ctx.strokeStyle='rgba(201,168,76,.3)';ctx.lineWidth=.5;
  ctx.beginPath();ctx.moveTo(p.px,p.py);ctx.lineTo(p2.px,p2.py);ctx.stroke();
  var rad=Math.min(canvas.width,canvas.height)*0.085*cam.zoom*.25;
  var grd=ctx.createRadialGradient(p2.px,p2.py,0,p2.px,p2.py,rad*3);
  grd.addColorStop(0,'rgba(201,168,76,.25)');grd.addColorStop(1,'rgba(201,168,76,0)');
  ctx.fillStyle=grd;ctx.beginPath();ctx.arc(p2.px,p2.py,rad*3,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='rgba(232,201,106,.9)';ctx.beginPath();ctx.arc(p2.px,p2.py,rad,0,Math.PI*2);ctx.fill();
}
function drawStool(ctx,obj,canvas,cam,highlight){
  var scale=Math.min(canvas.width,canvas.height)*0.085*cam.zoom;
  var seat={x:obj.x,y:0.72,z:obj.z,w:0.45,h:0.08,d:0.45,color:'#1a1008',edgeColor:highlight?'rgba(201,168,76,.8)':'rgba(201,168,76,.3)'};
  drawBox(ctx,seat,canvas,cam,highlight);
  var legOffsets=[[-0.18,0,-0.18],[0.18,0,-0.18],[-0.18,0,0.18],[0.18,0,0.18]];
  legOffsets.forEach(function(off){drawBox(ctx,{x:obj.x+off[0],y:0.35,z:obj.z+off[2],w:0.04,h:0.7,d:0.04,color:'#C9A84C',edgeColor:'rgba(201,168,76,.4)'},canvas,cam,false);});
}
function drawCylinder(ctx,obj,canvas,cam,highlight){
  var box={x:obj.x,y:obj.h/2,z:obj.z,w:obj.r*2,h:obj.h,d:obj.r*2,color:obj.color,edgeColor:obj.edgeColor,label:obj.label,labelColor:'rgba(0,201,184,.9)'};
  drawBox(ctx,box,canvas,cam,highlight);
  var pt=project3D(obj.x,obj.h,obj.z,canvas,cam);
  var scale=Math.min(canvas.width,canvas.height)*0.085*cam.zoom;
  ctx.fillStyle='rgba(220,220,220,.9)';ctx.strokeStyle=highlight?'rgba(201,168,76,.8)':obj.edgeColor;ctx.lineWidth=.5;
  ctx.beginPath();ctx.ellipse(pt.px,pt.py,obj.r*scale*.8,obj.r*scale*.3,0,0,Math.PI*2);ctx.fill();ctx.stroke();
  if(obj.label&&highlight){ctx.font='bold 9px Rajdhani,sans-serif';ctx.fillStyle='rgba(0,201,184,.9)';ctx.textAlign='center';ctx.fillText(obj.label,pt.px,pt.py-obj.r*scale*.4-4);}
}
var hoveredObj=null,labAnimTime=0;
function renderLab3D(){
  if(!lab3dCtx||!lab3dActive)return;
  labAnimTime+=0.012;
  cam.rotX+=(cam.targetRotX-cam.rotX)*.08;cam.rotY+=(cam.targetRotY-cam.rotY)*.08;cam.zoom+=(cam.targetZoom-cam.zoom)*.08;
  var c=lab3dCtx,w=lab3dCanvas.width,h=lab3dCanvas.height;
  c.clearRect(0,0,w,h);
  var bg=c.createLinearGradient(0,0,0,h);bg.addColorStop(0,'#07091A');bg.addColorStop(1,'#0C0F28');c.fillStyle=bg;c.fillRect(0,0,w,h);
  var glow=c.createRadialGradient(w/2,h*.6,0,w/2,h*.6,w*.4);glow.addColorStop(0,'rgba(0,201,184,.04)');glow.addColorStop(1,'rgba(0,201,184,0)');c.fillStyle=glow;c.fillRect(0,0,w,h);
  var sorted=LAB_OBJECTS.map(function(obj,i){var p=project3D(obj.x,0,obj.z,lab3dCanvas,cam);return{obj:obj,idx:i,depth:p.depth};}).sort(function(a,b){return b.depth-a.depth});
  sorted.forEach(function(item){
    var obj=item.obj,isHovered=(hoveredObj===item.idx);
    try{
      if(obj.type==='box')drawBox(c,obj,lab3dCanvas,cam,isHovered);
      else if(obj.type==='bottle')drawBottle(c,obj,lab3dCanvas,cam,isHovered);
      else if(obj.type==='glass')drawGlass(c,obj,lab3dCanvas,cam);
      else if(obj.type==='light')drawLight(c,obj,lab3dCanvas,cam);
      else if(obj.type==='stool')drawStool(c,obj,lab3dCanvas,cam,isHovered);
      else if(obj.type==='cylinder')drawCylinder(c,obj,lab3dCanvas,cam,isHovered);
      else if(obj.type==='equipment'){var eobj=Object.assign({},obj,{y:(obj.y||1.18)+(Math.sin(labAnimTime*0.7+item.idx)*.005)});drawBox(c,eobj,lab3dCanvas,cam,isHovered);}
    }catch(e){}
    if(obj.label&&!isHovered&&(obj.type==='bottle'||obj.type==='equipment'||obj.type==='cylinder')){
      var lp=project3D(obj.x,((obj.y||0)+(obj.h||0.6)+0.1),obj.z,lab3dCanvas,cam);
      c.font='6px Rajdhani,sans-serif';c.fillStyle='rgba(201,168,76,.3)';c.textAlign='center';c.fillText(obj.label,lp.px,lp.py);
    }
  });
  LAB_OBJECTS.forEach(function(obj){if(obj.type==='light'){
    var p=project3D(obj.x,obj.y-0.3,obj.z,lab3dCanvas,cam);
    var pulse=0.15+Math.sin(labAnimTime*1.2)*0.05;
    var grd=c.createRadialGradient(p.px,p.py,0,p.px,p.py,80);
    grd.addColorStop(0,'rgba(201,168,76,'+pulse+')');grd.addColorStop(1,'rgba(201,168,76,0)');
    c.fillStyle=grd;c.beginPath();c.arc(p.px,p.py,80,0,Math.PI*2);c.fill();
  }});
  c.strokeStyle='rgba(201,168,76,.2)';c.lineWidth=1;
  [[8,8,24,0],[w-8,8,w-24,0],[8,h-8,8,h-24],[w-8,h-8,w-24,h-8]].forEach(function(pts){c.beginPath();c.moveTo(pts[0],pts[1]);c.lineTo(pts[2],pts[3]);c.stroke();});
  lab3dRaf=requestAnimationFrame(renderLab3D);
}
function resizeLab(){if(!lab3dCanvas)return;var mi=lab3dCanvas.parentElement;lab3dCanvas.width=mi.clientWidth;lab3dCanvas.height=mi.clientHeight;}
function openLab3D(){lab3dModal.classList.add('open');lab3dActive=true;resizeLab();if(lab3dRaf)cancelAnimationFrame(lab3dRaf);renderLab3D();}
function closeLab3D(){lab3dModal.classList.remove('open');lab3dActive=false;if(lab3dRaf){cancelAnimationFrame(lab3dRaf);lab3dRaf=null;}}
lab3dBtn.addEventListener('click',openLab3D);
document.getElementById('MODAL-CLOSE').addEventListener('click',closeLab3D);
lab3dModal.addEventListener('click',function(e){if(e.target===lab3dModal)closeLab3D();});
lab3dCanvas.addEventListener('mousedown',function(e){mouse.down=true;mouse.lastX=e.clientX;mouse.lastY=e.clientY;});
window.addEventListener('mouseup',function(){mouse.down=false;});
window.addEventListener('mousemove',function(e){
  if(mouse.down){var dx=e.clientX-mouse.lastX,dy=e.clientY-mouse.lastY;cam.targetRotY+=dx*.008;cam.targetRotX=Math.max(0.05,Math.min(1.2,cam.targetRotX+dy*.006));mouse.lastX=e.clientX;mouse.lastY=e.clientY;}
});
lab3dCanvas.addEventListener('wheel',function(e){e.preventDefault();cam.targetZoom=Math.max(0.5,Math.min(2.5,cam.targetZoom-e.deltaY*.001));},{passive:false});
lab3dCanvas.addEventListener('touchstart',function(e){mouse.down=true;mouse.lastX=e.touches[0].clientX;mouse.lastY=e.touches[0].clientY;},{passive:true});
lab3dCanvas.addEventListener('touchmove',function(e){if(!mouse.down)return;var dx=e.touches[0].clientX-mouse.lastX,dy=e.touches[0].clientY-mouse.lastY;cam.targetRotY+=dx*.008;cam.targetRotX=Math.max(0.05,Math.min(1.2,cam.targetRotX+dy*.006));mouse.lastX=e.touches[0].clientX;mouse.lastY=e.touches[0].clientY;},{passive:true});
lab3dCanvas.addEventListener('touchend',function(){mouse.down=false;},{passive:true});
var VIEWS={full:{rotX:0.42,rotY:0.62,zoom:1.0},bar:{rotX:0.28,rotY:0.0,zoom:1.4},equip:{rotX:0.55,rotY:0.85,zoom:1.6},top:{rotX:1.15,rotY:0.62,zoom:1.1}};
['VIEW-FULL','VIEW-BAR','VIEW-EQUIP','VIEW-TOP'].forEach(function(id,i){
  var keys=['full','bar','equip','top'];
  var btn=document.getElementById(id);
  if(!btn)return;
  btn.addEventListener('click',function(){var v=VIEWS[keys[i]];cam.targetRotX=v.rotX;cam.targetRotY=v.rotY;cam.targetZoom=v.zoom;document.querySelectorAll('.ctrl-btn').forEach(function(b){b.classList.remove('active')});btn.classList.add('active');});
});
window.addEventListener('resize',function(){if(lab3dActive)resizeLab();});
setTimeout(navUpdate,80);
})();
