.glass-label{font-family:'Cinzel',serif;font-size:10px;letter-spacing:.15em;color:rgba(201,168,76,.5);text-align:center}
.builder-radar{margin-top:16px;display:flex;flex-direction:column;align-items:center;gap:4px}
.builder-radar-title{font-family:'Rajdhani',sans-serif;font-size:7px;letter-spacing:.3em;text-transform:uppercase;color:rgba(0,201,184,.45);font-weight:500}
