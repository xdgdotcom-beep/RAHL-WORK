<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Crowned Monkey · Project Plan 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #C9A96E;
    --gold-light: #E8D5A3;
    --dark: #0D0D0D;
    --surface: #141414;
    --surface2: #1C1C1C;
    --surface3: #242424;
    --text: #E8E4DC;
    --muted: #888;
    --accent: #C9A96E;
    --green: #4CAF80;
    --red: #E87060;
    --amber: #E8A860;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--dark);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    line-height: 1.6;
    min-height: 100vh;
  }

  /* HERO */
  .hero {
    position: relative;
    padding: 80px 60px 60px;
    border-bottom: 1px solid rgba(201,169,110,0.2);
    background: linear-gradient(135deg, #0D0D0D 0%, #1a1208 100%);
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -100px; right: -100px;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(201,169,110,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(44px, 6vw, 80px);
    font-weight: 300;
    letter-spacing: -1px;
    line-height: 1.1;
    color: var(--text);
    margin-bottom: 10px;
  }

  .hero-title em {
    font-style: italic;
    color: var(--gold);
  }

  .hero-subtitle {
    font-size: 14px;
    color: var(--muted);
    letter-spacing: 1px;
    margin-bottom: 48px;
  }

  .hero-meta {
    display: flex;
    gap: 48px;
    flex-wrap: wrap;
  }

  .meta-item label {
    display: block;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 4px;
  }

  .meta-item span {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 400;
    color: var(--gold);
  }

  /* NAV */
  nav {
    display: flex;
    gap: 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    background: var(--surface);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  nav a {
    padding: 16px 28px;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: all 0.2s;
    border-bottom: 2px solid transparent;
  }

  nav a:hover, nav a.active {
    color: var(--gold);
    border-bottom-color: var(--gold);
  }

  /* LAYOUT */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 60px;
  }

  .section { display: none; }
  .section.active { display: block; }

  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 36px;
    font-weight: 300;
    letter-spacing: -0.5px;
    color: var(--text);
    margin-bottom: 6px;
  }

  .section-desc {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 40px;
  }

  /* PHASE CARDS */
  .phases { display: grid; gap: 24px; }

  .phase-card {
    background: var(--surface);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .phase-card:hover { border-color: rgba(201,169,110,0.3); }

  .phase-header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 28px;
    cursor: pointer;
    user-select: none;
  }

  .phase-num {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: rgba(201,169,110,0.12);
    border: 1px solid rgba(201,169,110,0.3);
    display: flex; align-items: center; justify-content: center;
    font-size: 12px;
    color: var(--gold);
    font-weight: 500;
    flex-shrink: 0;
  }

  .phase-label {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 400;
    color: var(--text);
    flex: 1;
  }

  .phase-toggle {
    font-size: 18px;
    color: var(--muted);
    transition: transform 0.3s;
  }

  .phase-card.open .phase-toggle { transform: rotate(180deg); }

  .phase-tasks {
    display: none;
    padding: 0 28px 20px;
  }

  .phase-card.open .phase-tasks { display: block; }

  .task-row {
    display: grid;
    grid-template-columns: 1fr 140px 80px 120px;
    gap: 12px;
    align-items: center;
    padding: 12px 0;
    border-top: 1px solid rgba(255,255,255,0.04);
    font-size: 13px;
  }

  .task-name { color: var(--text); }
  .task-milestone { font-size: 11px; color: var(--gold); font-weight: 500; letter-spacing: 0.5px; }

  .task-dates { color: var(--muted); font-size: 12px; }
  .task-owner { color: var(--muted); font-size: 12px; text-align: right; }

  .badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 20px;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .badge-not-started { background: rgba(136,136,136,0.12); color: var(--muted); }
  .badge-in-progress { background: rgba(232,168,96,0.12); color: var(--amber); }
  .badge-complete { background: rgba(76,175,128,0.12); color: var(--green); }
  .badge-target { background: rgba(201,169,110,0.15); color: var(--gold); }

  /* GANTT */
  .gantt-wrap { overflow-x: auto; }
  .gantt-table { width: 100%; border-collapse: collapse; min-width: 900px; }

  .gantt-table th {
    padding: 10px 16px;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    text-align: left;
    background: var(--surface2);
  }

  .gantt-table th.week { text-align: center; font-size: 9px; }

  .gantt-table td {
    padding: 10px 16px;
    font-size: 13px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    vertical-align: middle;
  }

  .gantt-table tr:hover td { background: rgba(255,255,255,0.02); }

  .gantt-phase-row td {
    background: rgba(201,169,110,0.05);
    color: var(--gold);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 8px 16px;
    border-bottom: 1px solid rgba(201,169,110,0.1);
  }

  .bar-cell { text-align: center; }

  .bar-filled {
    display: inline-block;
    width: 24px; height: 8px;
    background: var(--gold);
    border-radius: 2px;
    opacity: 0.7;
  }

  .bar-milestone {
    display: inline-block;
    width: 10px; height: 10px;
    background: var(--gold);
    transform: rotate(45deg);
    border-radius: 1px;
  }

  /* BUDGET */
  .budget-summary {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 48px;
  }

  .kpi-card {
    background: var(--surface);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 24px 28px;
  }

  .kpi-card label {
    display: block;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
  }

  .kpi-card .value {
    font-family: 'Cormorant Garamond', serif;
    font-size: 32px;
    font-weight: 400;
    color: var(--gold);
  }

  .kpi-card .sub { font-size: 12px; color: var(--muted); margin-top: 4px; }

  .budget-table { width: 100%; border-collapse: collapse; }

  .budget-table th {
    padding: 10px 16px;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    text-align: left;
    background: var(--surface2);
  }

  .budget-table th:last-child, .budget-table td:last-child { text-align: right; }

  .budget-table td {
    padding: 11px 16px;
    font-size: 13px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }

  .budget-table tr:hover td { background: rgba(255,255,255,0.02); }

  .budget-cat-row td {
    background: rgba(201,169,110,0.05);
    color: var(--gold);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 8px 16px;
    border-bottom: 1px solid rgba(201,169,110,0.1);
  }

  .total-row td {
    font-weight: 500;
    color: var(--gold);
    border-top: 1px solid rgba(201,169,110,0.3);
    padding-top: 14px;
    font-size: 14px;
  }

  .cat-pill {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 20px;
    font-size: 10px;
    font-weight: 500;
    background: rgba(201,169,110,0.1);
    color: var(--gold-light);
  }

  /* ROI */
  .roi-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 40px; }

  .roi-section {
    background: var(--surface);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 28px;
  }

  .roi-section h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 300;
    color: var(--gold);
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .roi-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 9px 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    font-size: 13px;
  }

  .roi-row:last-child { border-bottom: none; }
  .roi-row .label { color: var(--muted); }
  .roi-row .val { color: var(--text); font-weight: 400; }
  .roi-row .val.highlight { color: var(--gold); font-family: 'Cormorant Garamond', serif; font-size: 18px; }
  .roi-row .val.pos { color: var(--green); }

  .ramp-table { width: 100%; border-collapse: collapse; margin-top: 20px; }
  .ramp-table th {
    padding: 8px 12px; font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--muted); font-weight: 500; border-bottom: 1px solid rgba(255,255,255,0.08);
    text-align: center; background: var(--surface2);
  }
  .ramp-table th:first-child { text-align: left; }
  .ramp-table td {
    padding: 9px 12px; font-size: 12px; border-bottom: 1px solid rgba(255,255,255,0.04);
    text-align: center;
  }
  .ramp-table td:first-child { text-align: left; color: var(--muted); font-size: 11px; letter-spacing: 0.5px; text-transform: uppercase; }

  .util-bar {
    display: inline-block;
    height: 6px;
    background: var(--gold);
    border-radius: 3px;
    opacity: 0.6;
    vertical-align: middle;
    margin-right: 6px;
    transition: opacity 0.2s;
  }

  /* RISK */
  .risk-table { width: 100%; border-collapse: collapse; }

  .risk-table th {
    padding: 10px 16px;
    font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--muted); font-weight: 500;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    text-align: left; background: var(--surface2);
  }

  .risk-table td {
    padding: 14px 16px; font-size: 13px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    vertical-align: top;
  }

  .risk-table tr:hover td { background: rgba(255,255,255,0.02); }

  .risk-desc { color: var(--text); }
  .risk-impact { color: var(--muted); font-size: 12px; margin-top: 4px; }

  .level-high { color: var(--red); font-weight: 500; }
  .level-medium { color: var(--amber); font-weight: 500; }
  .level-low { color: var(--green); font-weight: 500; }

  .mitigation { color: var(--muted); font-size: 12px; line-height: 1.5; }

  /* FOOTER */
  footer {
    text-align: center;
    padding: 40px;
    border-top: 1px solid rgba(255,255,255,0.06);
    color: var(--muted);
    font-size: 11px;
    letter-spacing: 1px;
  }

  footer span { color: var(--gold); }

  @media (max-width: 768px) {
    .hero { padding: 48px 24px 40px; }
    .container { padding: 40px 24px; }
    nav a { padding: 14px 16px; font-size: 11px; }
    .roi-grid { grid-template-columns: 1fr; }
    .task-row { grid-template-columns: 1fr auto; }
    .task-dates, .task-owner { display: none; }
  }
</style>
</head>
<body>

<!-- HERO -->
<div class="hero">
  <div class="hero-eyebrow">Four Seasons Resort Nevis · F&B Strategic Initiative · Confidential</div>
  <h1 class="hero-title">The <em>Crowned</em> Monkey</h1>
  <p class="hero-subtitle">Rum Bar → Molecular Mixology Lab &nbsp;·&nbsp; Project Plan 2026</p>
  <div class="hero-meta">
    <div class="meta-item"><label>Timeline</label><span>Apr – Jun 2026</span></div>
    <div class="meta-item"><label>Total Investment</label><span>$73,500</span></div>
    <div class="meta-item"><label>Payback Period</label><span>~6.3 months</span></div>
    <div class="meta-item"><label>Grand Opening</label><span>15 Jun 2026</span></div>
  </div>
</div>

<!-- NAV -->
<nav>
  <a href="#" class="active" onclick="showSection('plan', this)">Project Plan</a>
  <a href="#" onclick="showSection('gantt', this)">Timeline</a>
  <a href="#" onclick="showSection('budget', this)">OS&E Budget</a>
  <a href="#" onclick="showSection('roi', this)">ROI Model</a>
  <a href="#" onclick="showSection('risk', this)">Risk Register</a>
</nav>

<!-- PROJECT PLAN -->
<div id="plan" class="section active">
  <div class="container">
    <h2 class="section-title">Project Plan</h2>
    <p class="section-desc">Five phases from concept approval to grand opening · Click each phase to expand tasks</p>

    <div class="phases">

      <!-- PHASE 1 -->
      <div class="phase-card open">
        <div class="phase-header" onclick="togglePhase(this)">
          <div class="phase-num">1</div>
          <div class="phase-label">Foundation &amp; Approvals</div>
          <div class="phase-toggle">▾</div>
        </div>
        <div class="phase-tasks">
          <div class="task-row">
            <div><div class="task-name task-milestone">◆ Concept sign-off &amp; budget approval</div></div>
            <div class="task-dates">14 Apr – 16 Apr &nbsp;·&nbsp; 2 days</div>
            <div><span class="badge badge-not-started">Not Started</span></div>
            <div class="task-owner">Avi / Laura</div>
          </div>
          <div class="task-row">
            <div><div class="task-name task-milestone">◆ Space assessment &amp; layout design</div></div>
            <div class="task-dates">14 Apr – 27 Apr &nbsp;·&nbsp; 2 weeks</div>
            <div><span class="badge badge-not-started">Not Started</span></div>
            <div class="task-owner">Avi / Laura</div>
          </div>
          <div class="task-row">
            <div><div class="task-name">OS&amp;E procurement list finalized</div></div>
            <div class="task-dates">14 Apr – 18 Apr &nbsp;·&nbsp; 3 days</div>
            <div><span class="badge badge-not-started">Not Started</span></div>
            <div class="task-owner">Subhash</div>
          </div>
          <div class="task-row">
            <div><div class="task-name">Vendor sourcing &amp; quotes obtained</div></div>
            <div class="task-dates">14 Apr – 27 Apr &nbsp;·&nbsp; 2 weeks</div>
            <div><span class="badge badge-not-started">Not Started</span></div>
            <div class="task-owner">Subhash / Kristina</div>
          </div>
        </div>
      </div>

      <!-- PHASE 2 -->
      <div class="phase-card">
        <div class="phase-header" onclick="togglePhase(this)">
          <div class="phase-num">2</div>
          <div class="phase-label">Procurement, Renovation &amp; Build-Out</div>
          <div class="phase-toggle">▾</div>
        </div>
        <div class="phase-tasks">
          <div class="task-row"><div><div class="task-name task-milestone">◆ OS&amp;E orders placed</div></div><div class="task-dates">21 Apr &nbsp;·&nbsp; 1 day</div><div><span class="badge badge-not-started">Not Started</span></div><div class="task-owner">Avi / Laura</div></div>
          <div class="task-row"><div><div class="task-name task-milestone">◆ Logo placement at entrance</div></div><div class="task-dates">21 Apr – 11 May &nbsp;·&nbsp; 3 weeks</div><div><span class="badge badge-not-started">Not Started</span></div><div class="task-owner">Avi / Laura</div></div>
          <div class="task-row"><div><div class="task-name task-milestone">◆ Lighting &amp; ambiance</div></div><div class="task-dates">28 Apr – 11 May &nbsp;·&nbsp; 2 weeks</div><div><span class="badge badge-not-started">Not Started</span></div><div class="task-owner">Subhash / Kristina</div></div>
          <div class="task-row"><div><div class="task-name task-milestone">◆ Blackout curtain / divider CM-ESQ</div></div><div class="task-dates">Apr – May</div><div><span class="badge badge-not-started">Not Started</span></div><div class="task-owner">Avi / Laura</div></div>
          <div class="task-row"><div><div class="task-name task-milestone">◆ Molecular equipment delivery &amp; setup</div></div><div class="task-dates">5 May – 18 May &nbsp;·&nbsp; 2 weeks</div><div><span class="badge badge-not-started">Not Started</span></div><div class="task-owner">Subhash</div></div>
          <div class="task-row"><div><div class="task-name task-milestone">◆ Glassware &amp; serveware delivery</div></div><div class="task-dates">5 May – 18 May &nbsp;·&nbsp; 2 weeks</div><div><span class="badge badge-not-started">Not Started</span></div><div class="task-owner">Subhash</div></div>
          <div class="task-row"><div><div class="task-name">Inventory list</div></div><div class="task-dates">14 Apr</div><div><span class="badge badge-not-started">Not Started</span></div><div class="task-owner">Subhash</div></div>
          <div class="task-row"><div><div class="task-name">LN2 local vendor confirmed</div></div><div class="task-dates">14 Apr – 21 Apr &nbsp;·&nbsp; 1 week</div><div><span class="badge badge-not-started">Not Started</span></div><div class="task-owner">Subhash</div></div>
          <div class="task-row"><div><div class="task-name">Supplies PAR list</div></div><div class="task-dates">14 Apr – 21 Apr</div><div><span class="badge badge-not-started">Not Started</span></div><div class="task-owner">Subhash</div></div>
          <div class="task-row"><div><div class="task-name">Cocktail menu R&amp;D &amp; recipe development</div></div><div class="task-dates">14 Apr – 21 Apr</div><div><span class="badge badge-not-started">Not Started</span></div><div class="task-owner">Subhash</div></div>
          <div class="task-row"><div><div class="task-name">Recipes &amp; costing</div></div><div class="task-dates">14 Apr – 21 Apr</div><div><span class="badge badge-not-started">Not Started</span></div><div class="task-owner">Subhash</div></div>
          <div class="task-row"><div><div class="task-name">Order guide</div></div><div class="task-dates">14 Apr – 21 Apr</div><div><span class="badge badge-not-started">Not Started</span></div><div class="task-owner">Subhash / Kristina</div></div>
          <div class="task-row"><div><div class="task-name">Bar set up</div></div><div class="task-dates">14 Apr – 21 Apr</div><div><span class="badge badge-not-started">Not Started</span></div><div class="task-owner">Subhash / Kristina</div></div>
        </div>
      </div>

      <!-- PHASE 3 -->
      <div class="phase-card">
        <div class="phase-header" onclick="togglePhase(this)">
          <div class="phase-num">3</div>
          <div class="phase-label">Talent, Menu &amp; Training</div>
          <div class="phase-toggle">▾</div>
        </div>
        <div class="phase-tasks">
          <div class="task-row"><div><div class="task-name">Bar team molecular mixology training</div></div><div class="task-dates">12 May – 25 May &nbsp;·&nbsp; 2 weeks</div><div><span class="badge badge-not-started">Not Started</span></div><div class="task-owner">Subhash / Kristina</div></div>
          <div class="task-row"><div><div class="task-name">Service standards &amp; theatrical presentation</div></div><div class="task-dates">12 May – 25 May &nbsp;·&nbsp; 2 weeks</div><div><span class="badge badge-not-started">Not Started</span></div><div class="task-owner">Subhash / Kristina</div></div>
          <div class="task-row"><div><div class="task-name task-milestone">Opening beverage inventory ordered</div></div><div class="task-dates">18 May &nbsp;·&nbsp; 1 day</div><div><span class="badge badge-not-started">Not Started</span></div><div class="task-owner">Subhash / Kristina</div></div>
        </div>
      </div>

      <!-- PHASE 4 -->
      <div class="phase-card">
        <div class="phase-header" onclick="togglePhase(this)">
          <div class="phase-num">4</div>
          <div class="phase-label">Brand, Marketing &amp; Communications</div>
          <div class="phase-toggle">▾</div>
        </div>
        <div class="phase-tasks">
