<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Crowned Monkey · Project Plan 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --gold: #B8965A;
  --gold-bright: #D4AE72;
  --gold-pale: #E8D5A8;
  --gold-dim: rgba(184,150,90,0.15);
  --ink: #0A0906;
  --paper: #F7F3EC;
  --paper2: #EFE9DC;
  --cream: #FAF7F2;
  --border: rgba(184,150,90,0.18);
  --border-strong: rgba(184,150,90,0.35);
  --text-dark: #1C1810;
  --text-body: #3D3628;
  --text-muted: #8A7D67;
  --text-faint: #B5A990;
  --red: #C0503A;
  --amber-c: #C08040;
  --green: #4A7C5A;
  --sidebar-w: 240px;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--paper);color:var(--text-body);font-family:'Jost',sans-serif;font-weight:300;min-height:100vh;display:flex;}

/* SIDEBAR */
.sidebar{width:var(--sidebar-w);min-height:100vh;background:var(--ink);position:fixed;top:0;left:0;display:flex;flex-direction:column;z-index:200;border-right:1px solid rgba(184,150,90,0.12);}
.sidebar-brand{padding:40px 28px 32px;border-bottom:1px solid rgba(255,255,255,0.05);}
.sidebar-crown{font-size:24px;margin-bottom:12px;display:block;color:var(--gold);}
.sidebar-name{font-family:'Playfair Display',serif;font-size:18px;font-weight:500;color:var(--gold-pale);line-height:1.2;letter-spacing:0.3px;}
.sidebar-sub{font-size:10px;font-weight:400;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-top:6px;opacity:0.6;}
.sidebar-nav{flex:1;padding:24px 0;}
.nav-label{font-size:9px;letter-spacing:2.5px;text-transform:uppercase;color:rgba(255,255,255,0.2);padding:0 28px;margin-bottom:8px;margin-top:20px;}
.nav-link{display:flex;align-items:center;gap:12px;padding:11px 28px;font-size:12px;font-weight:400;letter-spacing:0.8px;color:rgba(255,255,255,0.4);cursor:pointer;transition:all 0.2s;position:relative;border:none;background:none;width:100%;text-align:left;}
.nav-link::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2px;background:var(--gold);opacity:0;transition:opacity 0.2s;}
.nav-link:hover{color:rgba(255,255,255,0.7);background:rgba(255,255,255,0.03);}
.nav-link.active{color:var(--gold-pale);background:rgba(184,150,90,0.08);}
.nav-link.active::before{opacity:1;}
.nav-icon{width:16px;text-align:center;font-size:12px;opacity:0.6;}
.sidebar-footer{padding:20px 28px;border-top:1px solid rgba(255,255,255,0.05);}
.sidebar-meta{font-size:10px;color:rgba(255,255,255,0.2);line-height:1.9;letter-spacing:0.5px;}
.sidebar-meta strong{color:rgba(255,255,255,0.35);font-weight:400;}

/* MAIN */
.main{margin-left:var(--sidebar-w);flex:1;min-height:100vh;}

/* HEADER */
.page-header{background:var(--ink);padding:56px 56px 48px;position:relative;overflow:hidden;}
.page-header::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);opacity:0.35;}
.page-header::before{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(184,150,90,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(184,150,90,0.03) 1px,transparent 1px);background-size:48px 48px;pointer-events:none;}
.header-eyebrow{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);opacity:0.75;margin-bottom:18px;display:flex;align-items:center;gap:10px;}
.header-eyebrow::before{content:'';display:inline-block;width:28px;height:1px;background:var(--gold);}
.header-title{font-family:'Playfair Display',serif;font-size:clamp(36px,4.5vw,60px);font-weight:400;color:#F2EAD8;line-height:1.1;letter-spacing:-0.5px;margin-bottom:6px;}
.header-title em{font-style:italic;color:var(--gold-bright);}
.header-tagline{font-size:13px;color:rgba(255,255,255,0.28);letter-spacing:1px;margin-bottom:40px;}
.header-stats{display:flex;gap:40px;flex-wrap:wrap;}
.stat{position:relative;}
.stat::after{content:'';position:absolute;right:-20px;top:8px;bottom:8px;width:1px;background:rgba(255,255,255,0.07);}
.stat:last-child::after{display:none;}
.stat-label{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.28);margin-bottom:5px;}
.stat-value{font-family:'Playfair Display',serif;font-size:22px;font-weight:400;color:var(--gold-bright);}

/* CONTENT */
.content{padding:48px 56px;}
.section{display:none;animation:fadeIn 0.25s ease;}
.section.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:none}}

/* SECTION HEADING */
.section-head{display:flex;align-items:baseline;gap:14px;margin-bottom:4px;}
.section-num{font-size:11px;letter-spacing:2px;color:var(--gold);font-weight:400;}
.section-title{font-family:'Playfair Display',serif;font-size:28px;font-weight:400;color:var(--text-dark);letter-spacing:-0.3px;}
.section-desc{font-size:12px;color:var(--text-faint);letter-spacing:0.5px;margin-bottom:36px;margin-top:4px;}
.divider{height:1px;background:linear-gradient(90deg,var(--border-strong),transparent);margin-bottom:36px;}

/* PHASE ACCORDION */
.phases{display:flex;flex-direction:column;gap:10px;}
.phase-card{background:white;border:1px solid var(--border);border-radius:3px;overflow:hidden;transition:border-color 0.2s,box-shadow 0.2s;}
.phase-card:hover{border-color:var(--border-strong);box-shadow:0 2px 16px rgba(184,150,90,0.07);}
.phase-header{display:flex;align-items:center;gap:14px;padding:17px 22px;cursor:pointer;user-select:none;background:white;transition:background 0.15s;}
.phase-header:hover{background:var(--cream);}
.phase-num{width:26px;height:26px;border-radius:50%;background:var(--ink);display:flex;align-items:center;justify-content:center;font-size:10px;color:var(--gold);font-weight:500;letter-spacing:0.5px;flex-shrink:0;}
.phase-label{font-family:'Playfair Display',serif;font-size:15.5px;font-weight:400;color:var(--text-dark);flex:1;}
.phase-count{font-size:11px;color:var(--text-faint);letter-spacing:0.5px;margin-right:6px;}
.phase-chevron{color:var(--text-faint);font-size:10px;transition:transform 0.3s;}
.phase-card.open .phase-chevron{transform:rotate(180deg);}
.phase-tasks{display:none;border-top:1px solid var(--border);}
.phase-card.open .phase-tasks{display:block;}

/* TASKS */
.task-head{display:grid;grid-template-columns:1fr 140px 100px 130px;gap:12px;padding:7px 22px;background:var(--paper2);border-bottom:1px solid var(--border);}
.task-head span{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--text-faint);font-weight:500;}
.task-row{display:grid;grid-template-columns:1fr 140px 100px 130px;gap:12px;align-items:center;padding:12px 22px;border-bottom:1px solid rgba(184,150,90,0.06);transition:background 0.15s;}
.task-row:last-child{border-bottom:none;}
.task-row:hover{background:var(--cream);}
.task-row.milestone-row{background:rgba(184,150,90,0.02);}
.task-name{font-size:13px;color:var(--text-body);line-height:1.4;}
.task-name.is-milestone{color:var(--text-dark);font-weight:400;}
.milestone-dot{color:var(--gold);margin-right:5px;}
.task-dates{font-size:11px;color:var(--text-muted);line-height:1.5;}
.task-owner{font-size:11px;color:var(--text-muted);}
.grand-opening{background:var(--ink) !important;border-top:1px solid rgba(184,150,90,0.25) !important;}
.grand-opening .task-name{color:var(--gold-pale);font-family:'Playfair Display',serif;font-size:15px;font-weight:400;font-style:italic;}
.grand-opening .task-dates{color:var(--gold);}
.grand-opening .task-owner{color:rgba(255,255,255,0.35);}

/* BADGES */
.badge{display:inline-flex;align-items:center;gap:5px;padding:3px 9px;border-radius:2px;font-size:9px;font-weight:500;letter-spacing:1px;text-transform:uppercase;}
.badge::before{content:'';width:5px;height:5px;border-radius:50%;flex-shrink:0;}
.badge-ns{background:rgba(138,125,103,0.1);color:var(--text-muted);}
.badge-ns::before{background:var(--text-faint);}
.badge-target{background:rgba(184,150,90,0.12);color:var(--gold);border:1px solid var(--border);}
.badge-target::before{background:var(--gold);}

/* GANTT */
.legend{display:flex;align-items:center;gap:24px;margin-bottom:18px;font-size:11px;color:var(--text-muted);}
.legend-item{display:flex;align-items:center;gap:7px;}
.leg-bar{width:20px;height:5px;border-radius:2px;}
.leg-bar.cp{background:var(--gold);opacity:0.85;}
.leg-bar.sp{background:var(--gold);opacity:0.42;}
.leg-ms{width:8px;height:8px;background:var(--gold);transform:rotate(45deg);border-radius:1px;display:inline-block;}
.gantt-scroll{overflow-x:auto;border:1px solid var(--border);border-radius:3px;background:white;}
.gantt-table{width:100%;border-collapse:collapse;min-width:860px;}
.gantt-table thead tr th{padding:11px 14px 5px;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--text-faint);font-weight:500;background:var(--paper2);border-bottom:1px solid var(--border);text-align:left;}
.gantt-table thead tr th.wk{text-align:center;}
.gantt-table td{padding:9px 14px;font-size:12px;border-bottom:1px solid rgba(184,150,90,0.06);vertical-align:middle;color:var(--text-body);}
.gantt-table tr:hover td{background:var(--cream);}
.gantt-phase-row td{background:var(--paper2);color:var(--gold);font-size:9px;font-weight:500;letter-spacing:2px;text-transform:uppercase;padding:7px 14px;border-bottom:1px solid var(--border);border-top:1px solid var(--border);}
.bc{text-align:center;}
.bar{display:inline-block;width:24px;height:6px;background:var(--gold);border-radius:2px;opacity:0.45;}
.bar.cp{opacity:0.82;}
.ms{display:inline-block;width:8px;height:8px;background:var(--gold);transform:rotate(45deg);border-radius:1px;}
.g-owner{font-size:10px;color:var(--text-faint);}

/* KPI / BUDGET */
.kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:36px;}
.kpi{background:white;border:1px solid var(--border);border-radius:3px;padding:20px 22px;position:relative;overflow:hidden;}
.kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--gold),transparent);}
.kpi-label{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--text-faint);margin-bottom:8px;font-weight:500;}
.kpi-value{font-family:'Playfair Display',serif;font-size:26px;font-weight:400;color:var(--gold);line-height:1;}
.kpi-note{font-size:11px;color:var(--text-faint);margin-top:5px;}
.budget-table{width:100%;border-collapse:collapse;background:white;border:1px solid var(--border);border-radius:3px;overflow:hidden;}
.budget-table thead th{padding:10px 16px;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--text-faint);font-weight:500;background:var(--paper2);border-bottom:1px solid var(--border);text-align:left;}
.budget-table thead th:nth-child(n+3){text-align:right;}
.budget-table td{padding:10px 16px;font-size:12.5px;border-bottom:1px solid rgba(184,150,90,0.06);color:var(--text-body);}
.budget-table td:nth-child(n+3){text-align:right;font-variant-numeric:tabular-nums;}
.budget-table tr:hover td{background:var(--cream);}
.budget-cat td{background:var(--paper2) !important;color:var(--gold) !important;font-size:9px !important;letter-spacing:2px;text-transform:uppercase;font-weight:500 !important;padding:7px 16px !important;border-top:1px solid var(--border);border-bottom:1px solid var(--border) !important;}
.total-row td{font-weight:500;color:var(--text-dark);border-top:1px solid var(--border-strong);background:var(--paper2) !important;padding:13px 16px;font-size:13px;}
.total-row td:nth-child(5){color:var(--gold);font-family:'Playfair Display',serif;font-size:18px;}
.cat-tag{display:inline-block;padding:2px 8px;border:1px solid var(--border);border-radius:2px;font-size:9px;letter-spacing:1px;text-transform:uppercase;color:var(--text-faint);font-weight:500;}

/* ROI */
.roi-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:30px;}
.roi-card{background:white;border:1px solid var(--border);border-radius:3px;overflow:hidden;}
.roi-card-head{padding:15px 22px 13px;border-bottom:1px solid var(--border);background:var(--paper2);}
.roi-card-head h3{font-family:'Playfair Display',serif;font-size:15px;font-weight:400;color:var(--text-dark);}
.roi-card-body{padding:6px 0;}
.roi-row{display:flex;justify-content:space-between;align-items:center;padding:8px 22px;border-bottom:1px solid rgba(184,150,90,0.06);font-size:12.5px;}
.roi-row:last-child{border-bottom:none;}
.roi-label{color:var(--text-muted);}
.roi-val{color:var(--text-dark);font-variant-numeric:tabular-nums;}
.roi-val.gold{color:var(--gold);font-family:'Playfair Display',serif;font-size:17px;}
.roi-val.pos{color:var(--green);}
.payback-strip{background:var(--ink);margin:4px 22px;padding:12px 16px;border-radius:2px;display:flex;justify-content:space-between;align-items:center;}
.payback-strip .roi-label{color:rgba(255,255,255,0.38);}
.payback-strip .roi-val{color:var(--gold-bright);font-family:'Playfair Display',serif;font-size:22px;}
.rev-table{width:100%;border-collapse:collapse;background:white;border:1px solid var(--border);border-radius:3px;overflow:hidden;}
.rev-table th{padding:9px 14px;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--text-faint);font-weight:500;background:var(--paper2);border-bottom:1px solid var(--border);text-align:center;}
.rev-table th:first-child{text-align:left;}
.rev-table td{padding:8px 14px;font-size:12px;border-bottom:1px solid rgba(184,150,90,0.06);text-align:center;color:var(--text-body);font-variant-numeric:tabular-nums;}
.rev-table td:first-child{text-align:left;color:var(--text-muted);font-size:11px;letter-spacing:0.5px;}
.rev-table tr:hover td{background:var(--cream);}
.rev-total td{background:var(--paper2) !important;color:var(--gold) !important;font-weight:500;border-top:1px solid var(--border);}
.util-bar-wrap{display:flex;align-items:center;gap:6px;justify-content:center;}
.util-bar{height:4px;background:var(--gold);border-radius:2px;opacity:0.5;display:inline-block;}

/* RISK */
.risk-table{width:100%;border-collapse:collapse;background:white;border:1px solid var(--border);border-radius:3px;overflow:hidden;}
.risk-table thead th{padding:10px 16px;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--text-faint);font-weight:500;background:var(--paper2);border-bottom:1px solid var(--border);text-align:left;}
.risk-table td{padding:14px 16px;font-size:12.5px;border-bottom:1px solid rgba(184,150,90,0.06);vertical-align:top;color:var(--text-body);}
.risk-table tr:hover td{background:var(--cream);}
.risk-name{color:var(--text-dark);font-weight:400;margin-bottom:3px;}
.risk-impact{font-size:11px;color:var(--text-faint);}
.risk-mitigation{font-size:11.5px;color:var(--text-muted);line-height:1.5;}
.lv{font-weight:500;font-size:11px;letter-spacing:0.5px;}
.lv-high{color:var(--red);}
.lv-med{color:var(--amber-c);}
.lv-low{color:var(--green);}

::-webkit-scrollbar{width:5px;height:5px;}
::-webkit-scrollbar-track{background:var(--paper2);}
::-webkit-scrollbar-thumb{background:var(--border-strong);border-radius:3px;}
::-webkit-scrollbar-thumb:hover{background:var(--gold);}

/* ========================================================
   RESPONSIVE DESIGN (MOBILE FITTING)
   ======================================================== */
@media (max-width: 900px) {
  body { flex-direction: column; display: block; }
  
  /* Convert Sidebar to Top Navigation */
  .sidebar {
    position: relative;
    width: 100%;
    min-height: auto;
    border-right: none;
    border-bottom: 1px solid var(--border-strong);
    z-index: 200;
  }
  
  .sidebar-brand {
    padding: 20px 24px 12px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .sidebar-crown { margin-bottom: 0; font-size: 20px; }
  .sidebar-name { font-size: 16px; text-align: right; line-height: 1.1; }
  .sidebar-name br { display: none; }
  .sidebar-sub { display: none; } /* Hidden to save vertical space */
  
  .sidebar-nav {
    padding: 0 16px 12px;
    display: flex;
    overflow-x: auto;
    gap: 8px;
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
  .sidebar-nav::-webkit-scrollbar { display: none; } /* Hide horizontal scrollbar */
  
  .nav-label { display: none; }
  .nav-link {
    width: auto;
    padding: 8px 14px;
    background: rgba(255,255,255,0.04);
    border-radius: 20px;
    text-align: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 11px;
  }
  .nav-link::before { display: none; }
  .nav-link.active { background: var(--gold); color: var(--ink); font-weight: 500; }
  
  .sidebar-footer { display: none; }
  
  /* Main Content Adjustments */
  .main { margin-left: 0; width: 100%; }
  .page-header { padding: 32px 24px 24px; }
  .header-eyebrow { font-size: 9px; line-height: 1.4; }
  .header-title { font-size: 32px; }
  .header-stats { gap: 20px; flex-direction: column; }
  .stat::after { display: none; } /* Remove stat dividers */
  
  .content { padding: 24px 16px; }
  
  /* Task List Responsiveness */
  .task-head { display: none; } /* Hide grid headers on mobile */
  .task-row {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 16px;
    gap: 8px;
  }
  .task-name { font-size: 14px; }
  .task-dates, .task-owner { display: inline-block; }
  
  /* Grids to Columns */
  .kpi-row { grid-template-columns: 1fr 1fr; gap: 12px; }
  .roi-grid { grid-template-columns: 1fr; }
  
  /* Make all Tables swipeable/scrollable horizontally */
  .budget-table, .rev-table, .risk-table {
    display: block;
    overflow-x: auto;
    white-space: nowrap;
    -webkit-overflow-scrolling: touch;
  }
}

@media (max-width: 480px) {
  /* Ultra-small screen adjustments */
  .kpi-row { grid-template-columns: 1fr; }
  .header-title { font-size: 28px; }
  .section-title { font-size: 22px; }
}
</style>
</head>
<body>

<aside class="sidebar">
  <div class="sidebar-brand">
    <span class="sidebar-crown">♔</span>
    <div class="sidebar-name">The Crowned Monkey</div>
    <div class="sidebar-sub">Project Plan 2026</div>
  </div>
  <nav class="sidebar-nav">
    <div class="nav-label">Navigation</div>
    <button class="nav-link active" onclick="show('plan',this)"><span class="nav-icon">◫</span>Project Plan</button>
    <button class="nav-link" onclick="show('gantt',this)"><span class="nav-icon">▦</span>Timeline</button>
    <button class="nav-link" onclick="show('budget',this)"><span class="nav-icon">◈</span>OS&amp;E Budget</button>
    <button class="nav-link" onclick="show('roi',this)"><span class="nav-icon">◉</span>ROI Model</button>
    <button class="nav-link" onclick="show('risk',this)"><span class="nav-icon">◇</span>Risk Register</button>
  </nav>
  <div class="sidebar-footer">
    <div class="sidebar-meta">
      <strong>Four Seasons Nevis</strong><br>
      F&amp;B Strategic Initiative<br>
      Apr – Jun 2026<br>
      <span style="color:rgba(184,150,90,0.45);margin-top:6px;display:block">Confidential</span>
    </div>
  </div>
</aside>

<div class="main">
  <header class="page-header">
    <div class="header-eyebrow">Four Seasons Resort Nevis · F&amp;B Strategic Initiative</div>
    <h1 class="header-title">The <em>Crowned</em> Monkey</h1>
    <p class="header-tagline">Rum Bar → Molecular Mixology Lab &nbsp;·&nbsp; April – June 2026</p>
    <div class="header-stats">
      <div class="stat"><div class="stat-label">Grand Opening</div><div class="stat-value">15 Jun 2026</div></div>
      <div class="stat"><div class="stat-label">Total Investment</div><div class="stat-value">$73,500</div></div>
      <div class="stat"><div class="stat-label">Payback Period</div><div class="stat-value">~6.3 months</div></div>
      <div class="stat"><div class="stat-label">5-Year Gain</div><div class="stat-value">$629,592</div></div>
    </div>
  </header>

  <div class="content">

    <div id="plan" class="section active">
      <div class="section-head"><span class="section-num">01</span><h2 class="section-title">Project Plan</h2></div>
      <p class="section-desc">Five phases · Concept approval through grand opening · Click any phase to expand</p>
      <div class="divider"></div>
      <div class="phases">

        <div class="phase-card open">
          <div class="phase-header" onclick="togglePhase(this)">
            <div class="phase-num">I</div>
            <div class="phase-label">Foundation &amp; Approvals</div>
            <span class="phase-count">4 tasks</span><span class="phase-chevron">▾</span>
          </div>
